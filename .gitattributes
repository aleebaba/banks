# Auto-detect text files, normalize line endings to LF on commit
* text=auto eol=lf

# Force CRLF for Windows-only scripts
*.bat          text eol=crlf
*.cmd          text eol=crlf
*.ps1          text eol=crlf

# Mark binary files explicitly
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.woff         binary
*.woff2        binary
*.ttf          binary
*.otf          binary

# Exclude these from language stats (GitHub)
docs/superpowers/reviews/* linguist-documentation
*.artifact.json  linguist-generated